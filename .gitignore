# ============================
# Python
# ============================

# Virtual environment — everyone creates their own from requirements.txt
venv/

# Compiled Python files — auto-generated, machine-specific
__pycache__/
*.pyc
*.pyo

# Distribution and packaging files
*.egg-info/
dist/
build/


# ============================

# Auto-saved checkpoint files
.ipynb_checkpoints/

# ============================
# Operating System Files
# ============================

# macOS folder metadata
.DS_Store

# Windows thumbnail cache
Thumbs.db

# ============================
# IDE / Editor Settings
# ============================

# PyCharm settings
.idea/

# ============================
# Environment and Secrets
# ============================

# Environment variable files (may contain API keys or passwords)
.env

# ============================
# Project Output (generated by pipeline)
# ============================

# Output files are generated by running the code
data/output/

# ============================
# IDE and Editor Files
# ============================

# VS Code settings (personal editor configuration)
.vscode/

# Vim swap files (temporary files created while editing)
*.swp
*.swo

# ============================
#
# ============================
# Model Cache
# ============================

# Hugging Face downloads models here
# They're large (1-2 GB) and downloaded automatically on first run
.cache/


